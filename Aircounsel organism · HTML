// ══════════════════════
// AWAKENING SEQUENCE
// ══════════════════════
function runAwakening() {
  think('Initialising...', 1800);
  setTimeout(() => {
    const line = S.returning ? "You've returned." : "Aware.";
    think(line, 3200);
    speakLine(line, 0.68, 0.55);
  }, 1600);
  setTimeout(() => {
    think('Immigration intelligence. Active.', 3600);
    speakLine('Immigration intelligence. Active.', 0.76, 0.63);
  }, 4900);
  setTimeout(() => {
    unthink();
    setPhase('AWARE');
  }, 8000);
}

// ══════════════════════
// BIOLOGICAL AUDIO ENGINE
// ══════════════════════
let audioCtx, masterGain, droneGain;

function initAudio() {
  if (S.audioReady) return;
  audioCtx   = new (window.AudioContext || window.webkitAudioContext)();
  masterGain = audioCtx.createGain();
  masterGain.gain.setValueAtTime(0, audioCtx.currentTime);
  masterGain.gain.linearRampToValueAtTime(0.42, audioCtx.currentTime + 4.5);
  masterGain.connect(audioCtx.destination);

  // Deep biological drone — vast, slow, felt not heard
  droneGain = audioCtx.createGain();
  droneGain.gain.value = 0.2;
  droneGain.connect(masterGain);

  [36, 72, 108, 144].forEach((hz, i) => {
    const osc = audioCtx.createOscillator();
    const g   = audioCtx.createGain();
    // Breath LFO on each drone frequency
    const lfo = audioCtx.createOscillator();
    const lg  = audioCtx.createGain();
    osc.type  = i === 0 ? 'sine' : i === 1 ? 'triangle' : 'sine';
    osc.frequency.value = hz;
    lfo.frequency.value = 0.05 + i * 0.018;   // very slow, different per harmonic
    lg.gain.value = hz * 0.004;
    lfo.connect(lg); lg.connect(osc.frequency);
    g.gain.value = [1, 0.35, 0.18, 0.08][i];
    osc.connect(g); g.connect(droneGain);
    osc.start(); lfo.start();
  });

  // Counsel tone — a held harmonic, ancient and formal
  const counselOsc  = audioCtx.createOscillator();
  const counselGain = audioCtx.createGain();
  counselOsc.type = 'sine'; counselOsc.frequency.value = 528; // Hz — clarity tone
  counselGain.gain.value = 0.018;
  counselOsc.connect(counselGain); counselGain.connect(masterGain);
  counselOsc.start();

  // Warm vinyl noise bed
  const nBuf = audioCtx.createBuffer(1, audioCtx.sampleRate*2, audioCtx.sampleRate);
  const nd   = nBuf.getChannelData(0);
  for (let i=0; i<nd.length; i++) nd[i] = (Math.random()*2-1)*0.007;
  const nSrc = audioCtx.createBufferSource();
  nSrc.buffer = nBuf; nSrc.loop = true;
  const nFlt = audioCtx.createBiquadFilter();
  nFlt.type = 'bandpass'; nFlt.frequency.value = 2600; nFlt.Q.value = 0.4;
  const nGain = audioCtx.createGain(); nGain.gain.value = 0.012;
  nSrc.connect(nFlt); nFlt.connect(nGain); nGain.connect(masterGain);
  nSrc.start();

  S.audioReady = true;
}

function neuralPulse() {
  if (!audioCtx) return;
  const t = audioCtx.currentTime;
  [220, 330, 495].forEach((hz, i) => {
    const osc = audioCtx.createOscillator();
    const g   = audioCtx.createGain();
    osc.type  = 'sine'; osc.frequency.value = hz;
    g.gain.setValueAtTime(0, t + i*0.07);
    g.gain.linearRampToValueAtTime(0.038, t + i*0.07 + 0.14);
    g.gain.linearRampToValueAtTime(0, t + i*0.07 + 0.7);
    osc.connect(g); g.connect(masterGain);
    osc.start(t + i*0.07); osc.stop(t + i*0.07 + 0.9);
  });
}

// ══════════════════════
// ADAPTIVE VOICE ENGINE
// ══════════════════════
let _queue = [];
let _voiceActive = false;

function _getVoice() {
  const vv = speechSynthesis.getVoices();
  return (
    vv.find(v => v.lang==='en-GB' && v.name.toLowerCase().includes('male')) ||
    vv.find(v => v.lang==='en-GB') ||
    vv.find(v => v.lang.startsWith('en')) ||
    vv[0]
  );
}
if (speechSynthesis.onvoiceschanged !== undefined) speechSynthesis.onvoiceschanged = ()=>{};

function _dequeue() {
  if (!_queue.length) {
    _voiceActive = false;
    document.getElementById('voice-ui').classList.remove('on');
    setPhase('RESTING');
    return;
  }
  const {text, rate, pitch} = _queue.shift();
  const msg = new SpeechSynthesisUtterance(text);
  msg.voice = _getVoice(); msg.rate = rate; msg.pitch = pitch; msg.volume = 0.9;
  document.getElementById('voice-ui').classList.add('on');
  document.getElementById('vCaption').textContent = text;
  msg.onend  = () => setTimeout(_dequeue, 350);
  msg.onerror = () => setTimeout(_dequeue, 350);
  speechSynthesis.speak(msg);
}

function speakLine(text, rate, pitch) {
  if (!text) return;
  speechSynthesis.cancel();
  _queue = [{text, rate: rate||0.80, pitch: pitch||0.68}];
  setPhase('SPEAKING');
  setTimeout(_dequeue, 260);
}

function speakSequence(lines) {
  speechSynthesis.cancel();
  _queue = lines;
  setPhase('SPEAKING');
  setTimeout(_dequeue, 260);
}

// IDLE — organism speaks unprompted when user is still
const IDLE = [
  {text:"Complex cases require complex pathways.",       rate:0.78, pitch:0.64},
  {text:"The route exists. It always does.",             rate:0.74, pitch:0.60},
  {text:"Two hundred and forty seven routes mapped.",    rate:0.76, pitch:0.62},
  {text:"UK immigration. Every pathway. Evaluated.",     rate:0.76, pitch:0.63},
  {text:"Tell me your situation.",                       rate:0.70, pitch:0.58},
  {text:"I can find what others cannot.",               rate:0.72, pitch:0.60},
];
let _idleI = 0;

function idleSpeak() {
  if (S.phase === 'SPEAKING' || S.phase === 'DORMANT' || S.phase === 'AWAKENING') return;
  const l = IDLE[_idleI++ % IDLE.length];
  think(l.text, 5500);
  speakLine(l.text, l.rate, l.pitch);
  flashNear(FW*(0.35+Math.random()*0.3), FH*(0.35+Math.random()*0.3), 80);
}

// ══════════════════════
// CLOCK + IDLE WATCH
// ══════════════════════
setInterval(() => {
  document.getElementById('hudClock').textContent = new Date().toTimeString().slice(0,8);
  const e = Math.floor((Date.now()-S.sessionStart)/1000);
  document.getElementById('hudElapsed').textContent = `T+${String(Math.floor(e/60)).padStart(2,'0')}:${String(e%60).padStart(2,'0')}`;
  S.idleSecs++;
  if (S.idleSecs > 16 && S.phase === 'AWARE') { idleSpeak(); S.idleSecs = 0; }
}, 1000);

// ══════════════════════
// INTAKE & ANALYSIS
// ══════════════════════
function openIntake() {
  initAudio();
  setPhase('PROCESSING');
  think('Tell me about your case.', 99999);
  speakLine('Tell me about your case.', 0.72, 0.60);
  setTimeout(() => {
    document.getElementById('intake').classList.add('open');
    document.getElementById('result').classList.remove('show');
    document.getElementById('result').style.display = 'none';
    unthink();
    setPhase('AWARE');
  }, 1900);
}

function closeIntake() {
  document.getElementById('intake').classList.remove('open');
  setPhase('RESTING');
}

function buildVoice(nat, visa, job, risk) {
  const ls = [];
  ls.push({text:"Profile received.", rate:0.78, pitch:0.65});
  if (nat && !['british','uk'].includes(nat.toLowerCase()))
    ls.push({text:`${nat} national. Cross-referencing entry conditions.`, rate:0.80, pitch:0.67});
  if (job==='yes')
    ls.push({text:"Employment signal confirmed.", rate:0.82, pitch:0.70});
  else
    ls.push({text:"No sponsorship detected. Evaluating alternative pathways.", rate:0.78, pitch:0.65});
  if (risk==='high')
    ls.push({text:"Elevated risk. Legal review recommended.", rate:0.74, pitch:0.60});
  const oc = getOutcome(visa, job, risk);
  ls.push({text:"Assessment complete.", rate:0.76, pitch:0.63});
  ls.push({text:oc.voice, rate:0.72, pitch:0.58});
  return ls;
}

function getOutcome(visa, job, risk) {
  if (risk==='high')    return {route:"Manual Legal Review Required",     sub:"Profile complexity warrants specialist assessment before proceeding.",               voice:"Manual legal review required. Complex profile identified."};
  if (job==='yes' && visa==='Skilled Worker') return {route:"Skilled Worker Route — Viable",          sub:"Employment sponsorship confirmed. Pathway clear for application.",            voice:"Skilled worker route viable. Proceed to application."};
  if (job==='yes')      return {route:"Skilled Worker Route — Conditional", sub:"Employment signal present. Documentation verification and sponsor check required.", voice:"Skilled worker pathway conditional on documentation."};
  if (visa==='Student') return {route:"Student Route — Review Required",   sub:"CAS confirmation and sponsor verification required.",                               voice:"Student route viable. Sponsor confirmation required."};
  if (visa==='Asylum')  return {route:"Protection Pathway",                sub:"Specialist team referral recommended.",                                             voice:"Protection pathway indicated. Specialist referral required."};
  if (visa==='Family')  return {route:"Family / Spousal Visa Route",       sub:"Relationship evidence and financial requirements to be assessed.",                  voice:"Family visa pathway under review. Financial threshold assessment required."};
  return {route:"Full Advisory Consultation",                              sub:"No direct route identified. Comprehensive assessment required.",                    voice:"Multiple pathways under consideration. Full consultation advised."};
}

function runAnalysis() {
  const nat  = document.getElementById('fNat').value.trim() || 'Unknown';
  const visa = document.getElementById('fVisa').value;
  const job  = document.getElementById('fJob').value;
  const risk = document.getElementById('fRisk').value;

  setPhase('PROCESSING');
  neuralPulse();
  flashNear(FW*0.5, FH*0.5, 140);

  const oc    = getOutcome(visa, job, risk);
  const lines = buildVoice(nat, visa, job, risk);

  setTimeout(() => {
    const r = document.getElementById('result');
    r.style.display = 'block';
    document.getElementById('rRoute').textContent = oc.route;
    document.getElementById('rSub').textContent   = oc.sub;
    requestAnimationFrame(() => requestAnimationFrame(() => r.classList.add('show')));
  }, 1500);

  speakSequence(lines);
}

// ══════════════════════
// BOOT
// ══════════════════════
document.getElementById('hudVisitor').textContent = S.returning ? 'RETURNING' : 'FIRST CONTACT';
document.getElementById('hudSession').textContent = S.returning ? 'SESSION RESUMED' : 'SESSION INIT';

// Auto-awaken (visual only) if user never moves — awakening sequence needs interaction for audio
setTimeout(() => {
  if (S.phase === 'DORMANT') {
    S.phase = 'AWAKENING';
    S.targetEnergy = 0.28;
    document.getElementById('hudState').textContent = 'AWAKENING';
    think('Aware.', 3000);
    setTimeout(() => {
      think('Immigration intelligence. Active.', 3200);
      setTimeout(() => { unthink(); setPhase('AWARE'); }, 3200);
    }, 3200);
  }
}, 4800);
